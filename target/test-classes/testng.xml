<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="eCommerce Test Suite" verbose="1" parallel="false">

    <listeners>
        <listener class-name="listeners.ExtentReportListener"/>
        <listener class-name="listeners.RetryListener"/>
        <listener class-name="listeners.ScreenshotListener"/>
    </listeners>

    <!-- Smoke Tests -->
    <test name="Smoke Tests" preserve-order="true">
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.HomePageTest"/>
            <class name="tests.CartTest"/>
            <class name="tests.CheckoutTest"/>
        </classes>
    </test>

    <!-- Regression Tests -->
    <test name="Regression Tests" preserve-order="true">
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.HomePageTest"/>
            <class name="tests.ProductTest"/>
            <class name="tests.CartTest"/>
            <class name="tests.CheckoutTest"/>
            <class name="tests.SortingTest"/>
        </classes>
    </test>

</suite>
